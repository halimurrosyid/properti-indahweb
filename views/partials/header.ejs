<header class="bg-surface-container-lowest/92 w-full border-b border-border-light/80 shadow-sm sticky top-0 z-50 backdrop-blur-xl">
    <div class="flex justify-between items-center w-full px-container-margin md:px-stack-lg max-w-7xl mx-auto h-[68px]">
        <!-- Brand Logo -->
        <a href="/" class="text-headline-sm font-black text-primary flex items-center gap-2.5">
            <span class="w-9 h-9 rounded-lg bg-primary text-on-primary flex items-center justify-center shadow-sm">
                <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1;">real_estate_agent</span>
            </span>
            <span class="text-[22px] tracking-tight">1rumah.biz.id</span>
        </a>
        
        <!-- Desktop Navigation Links -->
        <nav class="hidden md:flex items-center gap-1">
            <a href="/catalog?listingType=SALE" class="nav-link text-label-md">Dijual</a>
            <a href="/catalog?listingType=RENT" class="nav-link text-label-md">Disewa</a>
            <a href="/catalog" class="nav-link text-label-md">Katalog</a>
            <a href="/packages" class="nav-link text-label-md">Paket Iklan</a>
            <a href="/artikel" class="nav-link text-label-md">Artikel</a>
        </nav>

        <!-- Action Controls -->
        <div class="hidden md:flex items-center gap-3">
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'super_admin' || user.role === 'admin') { %>
                    <a href="/admin/dashboard" class="nav-link text-label-md">Panel Admin</a>
                <% } %>
                <a href="/dashboard" class="nav-link text-label-md">Dashboard</a>
                <a href="/auth/logout" class="text-on-surface-variant hover:text-error transition-colors text-label-md font-bold px-3 py-2 rounded-lg">Keluar</a>
            <% } else { %>
                <a href="/auth/login" class="nav-link text-label-md">Masuk / Daftar</a>
            <% } %>
            <a href="/pasang-iklan" class="primary-action text-label-md px-5 py-2.5">
                <span class="material-symbols-outlined text-[18px]">add_circle</span> Pasang Iklan Gratis
            </a>
        </div>

        <!-- Mobile menu trigger -->
        <div class="flex md:hidden items-center gap-2">
            <button id="mobile-menu-btn" class="p-2 text-on-surface-variant hover:text-primary focus:outline-none">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>

    <!-- Mobile Drawer Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-border-light bg-surface-container-lowest py-4 px-container-margin space-y-4 shadow-md">
        <nav class="flex flex-col gap-3">
            <a href="/catalog?listingType=SALE" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Dijual</a>
            <a href="/catalog?listingType=RENT" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Disewa</a>
            <a href="/catalog" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Katalog</a>
            <a href="/packages" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Paket Iklan</a>
            <a href="/artikel" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Artikel</a>
            <hr class="border-border-light my-1" />
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'super_admin' || user.role === 'admin') { %>
                    <a href="/admin/dashboard" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Panel Admin</a>
                <% } %>
                <a href="/dashboard" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Dashboard (<%= user.name %>)</a>
                <a href="/auth/logout" class="text-on-surface-variant hover:text-error text-body-md font-semibold py-1">Keluar</a>
            <% } else { %>
                <a href="/auth/login" class="text-on-surface-variant hover:text-primary text-body-md font-semibold py-1">Masuk / Daftar</a>
            <% } %>
            <a href="/pasang-iklan" class="primary-action text-label-md px-4 py-2.5 w-full">
                <span class="material-symbols-outlined text-[18px]">add_circle</span> Pasang Iklan Gratis
            </a>
        </nav>
    </div>
</header>

<script>
    document.getElementById('mobile-menu-btn').addEventListener('click', function() {
        var menu = document.getElementById('mobile-menu');
        var icon = this.querySelector('.material-symbols-outlined');
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            icon.textContent = 'close';
        } else {
            menu.classList.add('hidden');
            icon.textContent = 'menu';
        }
    });
</script>
