<%
    const pathNow = typeof currentPath !== 'undefined' ? currentPath : '';
    const currentUser = typeof user !== 'undefined' ? user : null;
    const isAdminUser = currentUser && (currentUser.role === 'admin' || currentUser.role === 'super_admin');
    const isSuperAdminUser = currentUser && currentUser.role === 'super_admin';
    const isActive = (href, mode = 'exact') => {
        if (mode === 'prefix') return pathNow === href || pathNow.startsWith(href + '/');
        return pathNow === href;
    };
    const isBlogMainActive = pathNow === '/admin/blog'
        || pathNow === '/admin/blog/create'
        || /^\/admin\/blog\/\d+\/edit$/.test(pathNow);
    const sidebarItemBase = 'flex items-center gap-3.5 px-3.5 py-3 rounded-lg text-label-md font-bold transition-all min-h-12';
    const linkClass = (active) => active
        ? `${sidebarItemBase} bg-primary text-on-primary shadow-sm`
        : `${sidebarItemBase} text-on-surface-variant hover:text-primary hover:bg-primary/5`;
%>

<div id="dashboard-sidebar-overlay" class="fixed inset-0 bg-black/40 z-40 hidden lg:hidden"></div>

<aside id="dashboard-sidebar" class="fixed lg:sticky top-0 left-0 z-50 h-screen w-[280px] -translate-x-full lg:translate-x-0 bg-surface-container-lowest/95 backdrop-blur-xl border-r border-border-light shadow-xl lg:shadow-none transition-transform duration-200 flex flex-col">
    <div class="h-[76px] px-5 border-b border-border-light flex items-center justify-between">
        <a href="/dashboard" class="text-title-lg font-black text-primary flex items-center gap-3 min-w-0">
            <span class="w-10 h-10 rounded-lg bg-primary text-on-primary flex items-center justify-center shadow-sm shrink-0">
                <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1;">real_estate_agent</span>
            </span>
            <span class="truncate">1rumah.biz.id</span>
        </a>
        <button type="button" id="dashboard-sidebar-close" class="lg:hidden w-9 h-9 rounded-lg border border-border-light text-on-surface-variant flex items-center justify-center">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-3.5 py-6 space-y-7">
        <div class="space-y-2">
            <p class="px-3.5 pb-1 text-label-xs font-black text-outline uppercase tracking-wider">Workspace</p>
            <a href="/dashboard" class="<%= linkClass(isActive('/dashboard')) %>">
                <span class="material-symbols-outlined text-[20px]">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a href="/pasang-iklan" class="<%= linkClass(isActive('/pasang-iklan')) %>">
                <span class="material-symbols-outlined text-[20px]">add_circle</span>
                <span>Pasang Iklan</span>
            </a>
            <a href="/packages" class="<%= linkClass(isActive('/packages')) %>">
                <span class="material-symbols-outlined text-[20px]">workspace_premium</span>
                <span>Paket Iklan</span>
            </a>
            <a href="/catalog" class="<%= linkClass(isActive('/catalog')) %>">
                <span class="material-symbols-outlined text-[20px]">travel_explore</span>
                <span>Katalog Publik</span>
            </a>
        </div>

        <% if (isAdminUser) { %>
            <div class="space-y-2">
                <p class="px-3.5 pb-1 text-label-xs font-black text-outline uppercase tracking-wider">Admin</p>
                <a href="/admin/dashboard" class="<%= linkClass(isActive('/admin/dashboard')) %>">
                    <span class="material-symbols-outlined text-[20px]">admin_panel_settings</span>
                    <span>Panel Admin</span>
                </a>
                <a href="/admin/blog" class="<%= linkClass(isBlogMainActive) %>">
                    <span class="material-symbols-outlined text-[20px]">article</span>
                    <span>Artikel Blog</span>
                </a>
                <a href="/admin/blog/ai-jobs" class="<%= linkClass(isActive('/admin/blog/ai-jobs', 'prefix')) %>">
                    <span class="material-symbols-outlined text-[20px]">automation</span>
                    <span>Batch AI</span>
                </a>
                <a href="/admin/blog/categories" class="<%= linkClass(isActive('/admin/blog/categories', 'prefix')) %>">
                    <span class="material-symbols-outlined text-[20px]">category</span>
                    <span>Kategori Blog</span>
                </a>
                <% if (isSuperAdminUser) { %>
                    <a href="/admin/packages" class="<%= linkClass(isActive('/admin/packages', 'prefix')) %>">
                        <span class="material-symbols-outlined text-[20px]">payments</span>
                        <span>Paket Iklan</span>
                    </a>
                    <a href="/admin/emails" class="<%= linkClass(isActive('/admin/emails', 'prefix')) %>">
                        <span class="material-symbols-outlined text-[20px]">mail</span>
                        <span>Email</span>
                    </a>
                    <a href="/admin/locations" class="<%= linkClass(isActive('/admin/locations', 'prefix')) %>">
                        <span class="material-symbols-outlined text-[20px]">location_city</span>
                        <span>Lokasi Populer</span>
                    </a>
                <% } %>
            </div>
        <% } %>

        <div class="space-y-2">
            <p class="px-3.5 pb-1 text-label-xs font-black text-outline uppercase tracking-wider">Akun</p>
            <a href="/" class="<%= sidebarItemBase %> text-on-surface-variant hover:text-primary hover:bg-primary/5">
                <span class="material-symbols-outlined text-[20px]">home</span>
                <span>Beranda</span>
            </a>
            <a href="/auth/logout" class="<%= sidebarItemBase %> text-on-surface-variant hover:text-error hover:bg-error/5">
                <span class="material-symbols-outlined text-[20px]">logout</span>
                <span>Keluar</span>
            </a>
        </div>
    </nav>

    <div class="border-t border-border-light px-4 py-4 bg-surface-subtle/70">
        <div class="flex items-center gap-3 min-w-0">
            <div class="w-11 h-11 rounded-lg bg-primary/10 text-primary flex items-center justify-center font-black shrink-0">
                <%= currentUser && currentUser.name ? currentUser.name.trim().charAt(0).toUpperCase() : 'U' %>
            </div>
            <div class="min-w-0 leading-tight">
                <p class="text-label-md font-bold text-on-surface truncate"><%= currentUser ? currentUser.name : 'User' %></p>
                <p class="text-label-xs text-outline truncate mt-1"><%= currentUser ? currentUser.role : '' %></p>
            </div>
        </div>
    </div>
</aside>
