<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-12">
    <div class="flex flex-col md:flex-row gap-8">
        
        <!-- Filter Sidebar Card -->
        <aside class="w-full md:w-80 shrink-0">
            <div class="app-surface p-6 rounded-lg sticky top-24">
                <h2 class="text-title-lg font-bold text-on-surface mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">filter_alt</span> Filter Pencarian
                </h2>
                
                <form action="/catalog" method="GET" class="space-y-4">
                    <!-- Keyword -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Kata Kunci</label>
                        <input 
                            type="text" 
                            name="keyword" 
                            value="<%= filters.keyword || '' %>" 
                            placeholder="Cari jalan, komplek..." 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        />
                    </div>

                    <!-- Listing Type -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Tipe Transaksi</label>
                        <select 
                            name="listingType" 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        >
                            <option value="">Semua Tipe</option>
                            <option value="SALE" <%= filters.listingType === 'SALE' ? 'selected' : '' %>>Dijual</option>
                            <option value="RENT" <%= filters.listingType === 'RENT' ? 'selected' : '' %>>Disewa</option>
                        </select>
                    </div>

                    <!-- Category -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Kategori</label>
                        <select 
                            name="category" 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        >
                            <option value="">Semua Kategori</option>
                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.slug %>" <%= filters.category === cat.slug ? 'selected' : '' %>><%= cat.name %></option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>

                    <!-- City -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Kota</label>
                        <input 
                            type="text" 
                            name="city" 
                            value="<%= filters.city || '' %>" 
                            placeholder="Contoh: Jakarta" 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        />
                    </div>

                    <!-- District -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Kecamatan</label>
                        <input 
                            type="text" 
                            name="district" 
                            value="<%= filters.district || '' %>" 
                            placeholder="Contoh: Coblong" 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        />
                    </div>

                    <!-- Price range -->
                    <div class="space-y-1.5">
                        <label class="text-label-sm font-bold text-on-surface-variant">Harga Min (Rp)</label>
                        <input 
                            type="number" 
                            name="minPrice" 
                            value="<%= filters.minPrice || '' %>" 
                            placeholder="Harga minimal..." 
                            class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                        />
                    </div>

                    <!-- Bedrooms & Bathrooms -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-1.5">
                            <label class="text-label-sm font-bold text-on-surface-variant">Kamar Tidur</label>
                            <select 
                                name="bedrooms" 
                                class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                            >
                                <option value="">Semua</option>
                                <% [1, 2, 3, 4, 5].forEach(num => { %>
                                    <option value="<%= num %>" <%= (filters.bedrooms && parseInt(filters.bedrooms) === num) ? 'selected' : '' %>><%= num %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-label-sm font-bold text-on-surface-variant">Kamar Mandi</label>
                            <select 
                                name="bathrooms" 
                                class="w-full px-3.5 py-2 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                            >
                                <option value="">Semua</option>
                                <% [1, 2, 3, 4, 5].forEach(num => { %>
                                    <option value="<%= num %>" <%= (filters.bathrooms && parseInt(filters.bathrooms) === num) ? 'selected' : '' %>><%= num %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="pt-2 flex flex-col gap-2">
                        <button 
                            type="submit" 
                            class="primary-action w-full py-2.5 text-label-md cursor-pointer"
                        >
                            Terapkan Filter
                        </button>
                        <a 
                            href="/catalog" 
                            class="w-full border border-border-light text-center py-2.5 rounded-lg text-label-md font-semibold hover:bg-surface-subtle transition-all cursor-pointer text-on-surface block"
                        >
                            Reset Filter
                        </a>
                    </div>
                </form>
            </div>
        </aside>

        <!-- Listings Catalog Grid -->
        <section class="flex-grow space-y-6">
            <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length > 0) { %>
                <nav class="text-body-sm text-outline flex items-center gap-1.5 mb-2">
                    <% breadcrumbs.forEach((crumb, index) => { %>
                        <% if (index > 0) { %>
                            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                        <% } %>
                        <% if (index === breadcrumbs.length - 1) { %>
                            <span class="text-on-surface-variant font-medium"><%= crumb.label %></span>
                        <% } else { %>
                            <a href="<%= crumb.url %>" class="hover:text-primary transition-colors"><%= crumb.label %></a>
                        <% } %>
                    <% }) %>
                </nav>
            <% } %>

            <div class="flex justify-between items-center pb-4 border-b border-border-light">
                <h1 class="text-headline-sm font-black text-on-surface">
                    Direktori Properti <span class="text-primary text-title-md font-normal">(<%= totalResults %> Ditemukan)</span>
                </h1>
            </div>

            <!-- Custom Submitted success notification -->
            <% if (typeof submitted_success !== 'undefined' && submitted_success) { %>
                <div class="bg-primary/5 text-primary border border-primary/10 p-4 rounded-xl flex items-center gap-2">
                    <span class="material-symbols-outlined">check_circle</span>
                    <span class="text-body-sm font-medium">Iklan Anda berhasil dikirim! Sedang ditinjau oleh Admin untuk ditayangkan.</span>
                </div>
            <% } %>

            <% if (typeof properties === 'undefined' || properties.length === 0) { %>
                <div class="bg-surface-container-lowest border border-border-light p-16 text-center rounded-lg">
                    <span class="material-symbols-outlined text-outline text-[64px] mb-3">search_off</span>
                    <h3 class="text-title-lg font-bold text-on-surface mb-1">Properti Tidak Ditemukan</h3>
                    <p class="text-body-md text-on-surface-variant max-w-sm mx-auto">
                        Coba ubah kata kunci pencarian Anda atau perkecil filter lokasi/harga untuk melihat hasil lainnya.
                    </p>
                </div>
            <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 animate-fade-in">
                    <% properties.forEach(prop => { %>
                        <div class="property-card <%= prop.isFeatured ? 'border-2 border-primary bg-primary/[0.01]' : '' %> overflow-hidden flex flex-col relative">
                            <% if (prop.isFeatured) { %>
                                <div class="absolute top-3 right-3 bg-primary text-white text-[11px] font-bold px-2 py-0.5 rounded-md shadow-sm flex items-center gap-0.5 z-20">
                                    <span class="material-symbols-outlined text-[12px] font-bold">star</span> Premium
                                </div>
                            <% } %>
                            <div class="relative h-48 w-full bg-surface-container">
                                <% if (prop.images && prop.images.length > 0) { %>
                                    <img loading="lazy" decoding="async" src="<%= prop.images[0].url %>" alt="<%= prop.title %> - 1rumah.biz.id" title="<%= prop.title %>" class="object-cover w-full h-full" />
                                <% } else { %>
                                    <div class="absolute inset-0 bg-primary/5 flex items-center justify-center text-primary/45">
                                        <span class="material-symbols-outlined text-[48px]">image</span>
                                    </div>
                                <% } %>
                                <div class="absolute top-3 left-3 bg-whatsapp-green text-white text-label-sm font-bold px-2.5 py-1 rounded-full shadow-sm">
                                    <%= prop.listingType === 'RENT' ? 'DISEWA' : 'DIJUAL' %>
                                </div>
                                <button 
                                    class="absolute bottom-3 right-3 bg-surface-container-lowest/80 backdrop-blur text-on-surface hover:text-error w-8 h-8 rounded-full shadow flex items-center justify-center cursor-pointer transition-all z-20 favorite-card-btn"
                                    data-id="<%= prop.id %>"
                                    title="Simpan ke Favorit"
                                >
                                    <span class="material-symbols-outlined text-[18px] text-outline favorite-card-icon">favorite</span>
                                </button>
                            </div>
                            <div class="p-4 flex-grow flex flex-col justify-between space-y-3">
                                <div>
                                    <span class="text-primary text-label-sm font-bold"><%= prop.category.name %></span>
                                    <h3 class="text-title-md font-bold text-on-surface line-clamp-1 mt-1">
                                        <a href="/property/<%= prop.slug %>" class="hover:underline"><%= prop.title %></a>
                                    </h3>
                                    <p class="text-body-sm text-outline line-clamp-1 mt-0.5"><%= prop.city %>, <%= prop.province %></p>
                                    <p class="text-primary text-title-lg font-bold mt-2">
                                        Rp <%= Number(prop.price).toLocaleString('id-ID') %>
                                    </p>
                                </div>
                                <div class="flex justify-between items-center border-t border-border-light pt-3 text-outline text-label-sm">
                                    <span class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px]">square_foot</span> Lb <%= prop.buildingSize %>m²
                                    </span>
                                    <span class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px]">bed</span> <%= prop.bedrooms %> KT
                                    </span>
                                    <span class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px]">bathtub</span> <%= prop.bathrooms %> KM
                                    </span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Pagination -->
                <% if (totalPages > 1) { %>
                    <div class="pt-8 flex justify-center">
                        <nav class="pagination-links">
                            <ul>
                                <% if (currentPage > 1) { %>
                                    <li>
                                        <a href="/catalog?<%= new URLSearchParams({...filters, page: currentPage - 1}).toString() %>">
                                            <span class="material-symbols-outlined text-title-sm">chevron_left</span>
                                        </a>
                                    </li>
                                <% } %>
                                
                                <% for (let i = 1; i <= totalPages; i++) { %>
                                    <li>
                                        <% if (i === currentPage) { %>
                                            <span class="current"><%= i %></span>
                                        <% } else { %>
                                            <a href="/catalog?<%= new URLSearchParams({...filters, page: i}).toString() %>"><%= i %></a>
                                        <% } %>
                                    </li>
                                <% } %>

                                <% if (currentPage < totalPages) { %>
                                    <li>
                                        <a href="/catalog?<%= new URLSearchParams({...filters, page: currentPage + 1}).toString() %>">
                                            <span class="material-symbols-outlined text-title-sm">chevron_right</span>
                                        </a>
                                    </li>
                                <% } %>
                            </ul>
                        </nav>
                    </div>
                <% } %>
            <% } %>
        </section>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cardButtons = document.querySelectorAll('.favorite-card-btn');

        function getFavorites() {
            const favs = localStorage.getItem('properti_favorit');
            return favs ? JSON.parse(favs) : [];
        }

        function saveFavorites(favs) {
            localStorage.setItem('properti_favorit', JSON.stringify(favs));
        }

        function updateCardUIs() {
            const favs = getFavorites();
            cardButtons.forEach(btn => {
                const id = parseInt(btn.getAttribute('data-id'));
                const icon = btn.querySelector('.favorite-card-icon');
                if (favs.includes(id)) {
                    icon.classList.remove('text-outline');
                    icon.classList.add('text-error');
                    icon.style.fontVariationSettings = "'FILL' 1";
                } else {
                    icon.classList.add('text-outline');
                    icon.classList.remove('text-error');
                    icon.style.fontVariationSettings = "'FILL' 0";
                }
            });
        }

        cardButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                const id = parseInt(btn.getAttribute('data-id'));
                let favs = getFavorites();
                if (favs.includes(id)) {
                    favs = favs.filter(item => item !== id);
                } else {
                    favs.push(id);
                }
                saveFavorites(favs);
                updateCardUIs();
            });
        });

        updateCardUIs();
    });
</script>
