<div class="max-w-6xl mx-auto px-container-margin md:px-stack-lg py-10 space-y-8">
    <div class="bg-surface-container-lowest p-6 rounded-lg border border-border-light shadow-sm flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
            <h1 class="text-headline-md font-bold text-on-surface">Kelola Email</h1>
            <p class="text-body-sm text-on-surface-variant mt-1">Atur notifikasi email, penerima admin, dan pantau riwayat pengiriman.</p>
        </div>
        <div class="<%= smtpConfigured ? 'bg-green-50 text-green-800 border-green-200' : 'bg-yellow-50 text-yellow-800 border-yellow-200' %> border px-4 py-2 rounded-xl text-label-sm font-bold">
            SMTP <%= smtpConfigured ? 'Aktif' : 'Belum Diatur' %>
        </div>
    </div>

    <% if (message) { %>
        <div class="bg-green-50 text-green-800 border border-green-200 p-4 rounded-xl text-body-md font-medium"><%= message %></div>
    <% } %>
    <% if (error) { %>
        <div class="bg-red-50 text-red-800 border border-red-200 p-4 rounded-xl text-body-md font-medium"><%= error %></div>
    <% } %>

    <form action="/admin/emails/settings" method="POST" class="bg-surface-container-lowest rounded-lg border border-border-light shadow-sm p-5 space-y-5">
        <div class="space-y-1">
            <label class="text-label-sm font-bold text-on-surface block">Email Admin Penerima Notifikasi</label>
            <input type="text" name="admin_notification_email" value="<%= settings.admin_notification_email || '' %>" placeholder="admin@1rumah.biz.id, support@domain.com" class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
            <p class="text-label-xs text-outline">Pisahkan beberapa email dengan koma.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <% [
                ['email_verify_enabled', 'Verifikasi email akun'],
                ['email_reset_enabled', 'Reset password'],
                ['email_listing_notifications_enabled', 'Notifikasi listing user'],
                ['email_invoice_notifications_enabled', 'Notifikasi invoice/pembayaran'],
                ['email_package_notifications_enabled', 'Pengingat paket/featured expired'],
                ['email_admin_notifications_enabled', 'Notifikasi admin'],
                ['email_lead_notifications_enabled', 'Notifikasi lead WhatsApp']
            ].forEach(([key, label]) => { %>
                <label class="flex items-center gap-2 bg-surface-subtle border border-border-light rounded-xl px-3 py-2.5 text-label-sm font-bold text-on-surface">
                    <input type="checkbox" name="<%= key %>" <%= settings[key] !== 'false' ? 'checked' : '' %> class="accent-primary">
                    <span><%= label %></span>
                </label>
            <% }) %>
        </div>

        <div class="flex justify-end">
            <button type="submit" class="bg-primary hover:bg-surface-tint text-on-primary text-label-sm font-bold px-4 py-2.5 rounded-xl cursor-pointer">Simpan Pengaturan</button>
        </div>
    </form>

    <div class="bg-surface-container-lowest rounded-lg border border-border-light shadow-sm overflow-hidden">
        <div class="p-5 border-b border-border-light bg-surface-container-low/50">
            <h2 class="text-title-md font-bold text-on-surface">Email Log Terbaru</h2>
        </div>
        <% if (!logs || logs.length === 0) { %>
            <div class="p-8 text-center text-body-md text-on-surface-variant">Belum ada log email.</div>
        <% } else { %>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low text-label-sm font-bold text-on-surface-variant border-b border-border-light">
                            <th class="p-4">Waktu</th>
                            <th class="p-4">Penerima</th>
                            <th class="p-4">Template</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Subjek / Error</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        <% logs.forEach(log => { %>
                            <tr class="text-body-sm text-on-surface">
                                <td class="p-4 whitespace-nowrap"><%= formatJakartaDateTime(log.createdAt, { dateStyle: 'short', timeStyle: 'short' }) %></td>
                                <td class="p-4"><%= log.recipient %></td>
                                <td class="p-4 font-mono text-label-xs"><%= log.template %></td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded-full text-label-xs font-bold <%= log.status === 'sent' ? 'bg-green-50 text-green-700 border border-green-200' : log.status === 'failed' ? 'bg-red-50 text-red-700 border border-red-200' : log.status === 'skipped' ? 'bg-yellow-50 text-yellow-700 border border-yellow-200' : 'bg-surface-container-high text-on-surface-variant border border-border-light' %>"><%= log.status %></span>
                                </td>
                                <td class="p-4">
                                    <span class="font-semibold block"><%= log.subject %></span>
                                    <% if (log.errorMessage) { %>
                                        <span class="text-error text-label-xs block mt-1"><%= log.errorMessage %></span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
