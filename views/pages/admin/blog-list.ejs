<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-10 space-y-8">
    <%
      const perPageSuffix = pagination ? `&${pagination.perPageParam}=${pagination.perPage}` : '';
    %>
    <!-- Header Section -->
    <div class="bg-surface-container-lowest p-6 rounded-lg border border-border-light shadow-sm flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
            <h1 class="text-headline-md font-bold text-on-surface">Manajemen Artikel SEO</h1>
            <p class="text-body-sm text-on-surface-variant mt-1">Buat, kelola, dan otomatisasi artikel properti lokal Indonesia untuk mendorong traffic SEO.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <a href="/admin/blog/categories" class="text-on-surface-variant hover:text-primary transition-colors text-label-md font-bold px-4 py-2.5 rounded-xl border border-border-light flex items-center gap-1.5 bg-surface-container-lowest">
                <span class="material-symbols-outlined text-[18px]">category</span> Kategori
            </a>
            <a href="/admin/blog/ai-generate" class="text-secondary hover:text-secondary-variant font-bold text-label-md px-4 py-2.5 rounded-xl border border-secondary/20 bg-secondary/5 flex items-center gap-1.5 transition-all">
                <span class="material-symbols-outlined text-[18px]">psychology</span> AI Generator
            </a>
            <a href="/admin/blog/ai-jobs" class="text-on-surface-variant hover:text-primary font-bold text-label-md px-4 py-2.5 rounded-xl border border-border-light flex items-center gap-1.5 bg-surface-container-lowest">
                <span class="material-symbols-outlined text-[18px]">monitoring</span> Monitoring AI
            </a>
            <a href="/admin/blog/create" class="bg-primary hover:bg-surface-tint text-on-primary font-bold text-label-md px-5 py-2.5 rounded-full transition-all flex items-center gap-1.5 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">add</span> Tulis Manual
            </a>
        </div>
    </div>

    <!-- Feedback messages -->
    <% if (message) { %>
        <div class="bg-green-50 text-green-800 border border-green-200 p-4 rounded-xl text-body-md font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-green-600">check_circle</span>
            <%= message %>
        </div>
    <% } %>
    <% if (error) { %>
        <div class="bg-red-50 text-red-800 border border-red-200 p-4 rounded-xl text-body-md font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-red-600">error</span>
            <%= error %>
        </div>
    <% } %>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap gap-2">
        <a href="/admin/blog?<%= pagination.perPageParam %>=<%= pagination.perPage %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= !statusFilter && !sourceFilter ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Semua</a>
        <a href="/admin/blog?status=draft<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= statusFilter === 'draft' ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Draft</a>
        <a href="/admin/blog?status=published<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= statusFilter === 'published' ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Published</a>
        <a href="/admin/blog?status=scheduled<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= statusFilter === 'scheduled' ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Scheduled</a>
        <a href="/admin/blog?status=archived<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= statusFilter === 'archived' ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Archived</a>
        <a href="/admin/blog?status=deleted<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= statusFilter === 'deleted' ? 'bg-primary text-on-primary border-primary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Deleted (Soft Delete)</a>
        
        <span class="border-l border-border-light mx-2 my-1"></span>
        
        <a href="/admin/blog?source=manual<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= sourceFilter === 'manual' ? 'bg-secondary text-on-secondary border-secondary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">Manual</a>
        <a href="/admin/blog?source=ai<%= perPageSuffix %>" class="px-4 py-2 rounded-full font-bold text-label-sm border transition-all <%= sourceFilter === 'ai' ? 'bg-secondary text-on-secondary border-secondary' : 'bg-surface-container-lowest text-on-surface-variant border-border-light hover:bg-surface-container-low' %>">AI Generated</a>
    </div>

    <form id="bulk-action-form" action="/admin/blog/bulk-update" method="POST" class="bg-surface-container-lowest rounded-lg border border-border-light shadow-sm p-4 flex flex-col lg:flex-row lg:items-end gap-3">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 flex-grow">
            <div class="space-y-1">
                <label for="bulk_status" class="text-label-sm font-bold text-on-surface block">Status Massal</label>
                <select id="bulk_status" name="bulk_status" class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
                    <option value="__nochange">Tidak ubah status</option>
                    <option value="draft">Draft</option>
                    <option value="published">Published</option>
                    <option value="scheduled">Scheduled</option>
                    <option value="archived">Archived</option>
                    <option value="deleted">Deleted</option>
                </select>
            </div>
            <div class="space-y-1">
                <label for="bulk_category_id" class="text-label-sm font-bold text-on-surface block">Kategori Massal</label>
                <select id="bulk_category_id" name="bulk_category_id" class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
                    <option value="__nochange">Tidak ubah kategori</option>
                    <option value="__none">Tanpa kategori</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            <div class="space-y-1">
                <label for="bulk_scheduled_at" class="text-label-sm font-bold text-on-surface block">Jadwal Publish</label>
                <input type="datetime-local" id="bulk_scheduled_at" name="bulk_scheduled_at"
                       class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
            </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <button type="button" id="select-visible-posts" class="text-label-sm font-bold text-on-surface-variant hover:bg-surface-container-high px-3 py-2.5 rounded-xl border border-border-light cursor-pointer">
                Pilih Semua
            </button>
            <button type="submit" class="bg-primary hover:bg-surface-tint text-on-primary text-label-sm font-bold px-4 py-2.5 rounded-xl transition-all cursor-pointer">
                Terapkan Massal
            </button>
        </div>
    </form>

    <!-- Table Container -->
    <div class="bg-surface-container-lowest rounded-lg border border-border-light shadow-sm overflow-hidden">
        <div class="p-6 border-b border-border-light flex justify-between items-center bg-surface-container-low/50">
            <h2 class="text-title-lg font-bold text-on-surface font-display-md">Daftar Artikel (<%= totalPosts %>)</h2>
        </div>

        <% if (posts.length === 0) { %>
            <div class="p-12 text-center space-y-4">
                <span class="material-symbols-outlined text-[64px] text-outline">article</span>
                <p class="text-body-md text-on-surface-variant max-w-sm mx-auto">Tidak ada artikel yang terdaftar dalam kriteria filter ini.</p>
            </div>
        <% } else { %>
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low text-label-sm font-bold text-on-surface-variant border-b border-border-light">
                            <th class="p-4 w-10">
                                <input type="checkbox" id="bulk-check-all" class="w-4 h-4 accent-primary cursor-pointer" aria-label="Pilih semua artikel">
                            </th>
                            <th class="p-4">Cover</th>
                            <th class="p-4">Judul Artikel</th>
                            <th class="p-4">Kategori</th>
                            <th class="p-4">Source</th>
                            <th class="p-4">Status</th>
                            <th class="p-4">Waktu Publish</th>
                            <th class="p-4 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        <% posts.forEach(post => { %>
                            <tr class="hover:bg-surface-bright/50 transition-all text-body-md text-on-surface">
                                <td class="p-4">
                                    <input type="checkbox" name="selected_post_ids" value="<%= post.id %>" form="bulk-action-form" class="bulk-post-checkbox w-4 h-4 accent-primary cursor-pointer" aria-label="Pilih artikel <%= post.title %>">
                                </td>
                                <!-- Featured Image thumbnail -->
                                <td class="p-4">
                                    <% if (post.featured_image) { %>
                                        <img loading="lazy" decoding="async" src="<%= post.featured_image %>" alt="<%= post.title %> - 1rumah.biz.id" title="<%= post.title %>" class="w-16 h-10 object-cover rounded border border-border-light">
                                    <% } else { %>
                                        <div class="w-16 h-10 bg-surface-container-high rounded border border-border-light flex items-center justify-center text-outline">
                                            <span class="material-symbols-outlined text-[18px]">image</span>
                                        </div>
                                    <% } %>
                                </td>

                                <!-- Title and link -->
                                <td class="p-4">
                                    <span class="font-semibold text-on-surface block max-w-sm truncate"><%= post.title %></span>
                                    <a href="/artikel/<%= post.slug %>" target="_blank" class="text-label-xs text-primary hover:underline font-mono block mt-0.5">/artikel/<%= post.slug %></a>
                                </td>

                                <!-- Category -->
                                <td class="p-4 text-body-sm">
                                    <span class="font-semibold"><%= post.category ? post.category.name : '-' %></span>
                                </td>

                                <!-- Source -->
                                <td class="p-4 text-body-sm">
                                    <% if (post.source === 'ai') { %>
                                        <span class="bg-purple-100 text-purple-800 text-[11px] font-bold px-2 py-0.5 rounded border border-purple-200" title="Generated by Job Batch ID: <%= post.ai_job_id || '-' %>">
                                            AI: Batch <%= post.ai_job?.batch_name || post.ai_job_id || '-' %>
                                        </span>
                                    <% } else { %>
                                        <span class="bg-gray-100 text-gray-800 text-[11px] font-bold px-2 py-0.5 rounded border border-gray-200">
                                            Manual
                                        </span>
                                    <% } %>
                                </td>

                                <!-- Status Badge -->
                                <td class="p-4">
                                    <% if (post.status === 'published') { %>
                                        <span class="bg-green-100 text-green-800 text-label-xs font-bold px-2.5 py-1 rounded-full border border-green-200">Published</span>
                                    <% } else if (post.status === 'scheduled') { %>
                                        <span class="bg-blue-100 text-blue-800 text-label-xs font-bold px-2.5 py-1 rounded-full border border-blue-200">Scheduled</span>
                                    <% } else if (post.status === 'draft') { %>
                                        <span class="bg-yellow-100 text-yellow-800 text-label-xs font-bold px-2.5 py-1 rounded-full border border-yellow-200">Draft</span>
                                    <% } else if (post.status === 'archived') { %>
                                        <span class="bg-orange-100 text-orange-800 text-label-xs font-bold px-2.5 py-1 rounded-full border border-orange-200">Archived</span>
                                    <% } else if (post.status === 'deleted') { %>
                                        <span class="bg-red-100 text-red-800 text-label-xs font-bold px-2.5 py-1 rounded-full border border-red-200">Deleted</span>
                                    <% } %>
                                </td>

                                <!-- Publish / Scheduled date -->
                                <td class="p-4 text-body-sm text-outline">
                                    <% if (post.status === 'published') { %>
                                        <%= formatJakartaDateTime(post.published_at, { dateStyle: 'short', timeStyle: 'short' }) %>
                                    </td>
                                    <% } else if (post.status === 'scheduled') { %>
                                        <span class="text-blue-600 font-semibold">
                                            <%= formatJakartaDateTime(post.scheduled_at, { dateStyle: 'short', timeStyle: 'short' }) %>
                                        </span>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>

                                <!-- Actions -->
                                <td class="p-4 text-right">
                                    <div class="flex items-center justify-end gap-1.5">
                                        
                                        <% if (post.status !== 'deleted') { %>
                                            <!-- Edit -->
                                            <a href="/admin/blog/<%= post.id %>/edit" class="text-label-sm font-bold text-secondary hover:bg-secondary/5 px-2.5 py-1.5 rounded-lg border border-secondary/20 transition-all flex items-center justify-center" title="Edit Artikel">
                                                <span class="material-symbols-outlined text-[16px]">edit</span>
                                            </a>
                                            
                                            <% if (post.status !== 'archived') { %>
                                                <!-- Archive -->
                                                <form action="/admin/blog/<%= post.id %>/archive" method="POST" class="inline">
                                                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                                    <button type="submit" class="text-outline hover:text-orange-600 p-1.5 rounded-lg border border-border-light hover:border-orange-200 transition-all cursor-pointer flex items-center justify-center" title="Arsip Artikel">
                                                        <span class="material-symbols-outlined text-[16px]">archive</span>
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <!-- Restore from archive -->
                                                <form action="/admin/blog/<%= post.id %>/restore" method="POST" class="inline">
                                                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                                    <button type="submit" class="text-outline hover:text-green-600 p-1.5 rounded-lg border border-border-light hover:border-green-200 transition-all cursor-pointer flex items-center justify-center" title="Restore ke Draft">
                                                        <span class="material-symbols-outlined text-[16px]">unarchive</span>
                                                    </button>
                                                </form>
                                            <% } %>

                                            <!-- Soft Delete -->
                                            <form action="/admin/blog/<%= post.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus artikel ini?')">
                                                <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                                <button type="submit" class="text-outline hover:text-error p-1.5 rounded-lg border border-border-light hover:border-error/20 transition-all cursor-pointer flex items-center justify-center" title="Hapus Artikel">
                                                    <span class="material-symbols-outlined text-[16px]">delete</span>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <!-- Restore from soft delete -->
                                            <form action="/admin/blog/<%= post.id %>/restore" method="POST" class="inline">
                                                <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                                <button type="submit" class="text-green-600 bg-green-50 border border-green-200 px-3 py-1.5 rounded-lg hover:bg-green-100 transition-all cursor-pointer flex items-center gap-1 font-bold text-label-xs">
                                                    <span class="material-symbols-outlined text-[14px]">restore</span> Restore
                                                </button>
                                            </form>
                                        <% } %>

                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Mobile List Card -->
            <div class="block md:hidden divide-y divide-border-light">
                <% posts.forEach(post => { %>
                    <div class="p-4 space-y-3">
                        <div class="flex gap-3">
                            <input type="checkbox" name="selected_post_ids" value="<%= post.id %>" form="bulk-action-form" class="bulk-post-checkbox mt-4 w-4 h-4 accent-primary cursor-pointer flex-shrink-0" aria-label="Pilih artikel <%= post.title %>">
                            <% if (post.featured_image) { %>
                                <img loading="lazy" decoding="async" src="<%= post.featured_image %>" alt="<%= post.title %> - 1rumah.biz.id" title="<%= post.title %>" class="w-16 h-12 object-cover rounded border border-border-light flex-shrink-0 bg-surface-container-low">
                            <% } else { %>
                                <div class="w-16 h-12 bg-surface-container-high rounded border border-border-light flex items-center justify-center text-outline flex-shrink-0">
                                    <span class="material-symbols-outlined text-[20px]">image</span>
                                </div>
                            <% } %>
                            <div class="min-w-0 flex-grow">
                                <span class="font-semibold text-on-surface block truncate text-body-md"><%= post.title %></span>
                                <a href="/artikel/<%= post.slug %>" target="_blank" class="text-label-xs text-primary hover:underline font-mono block mt-0.5 truncate">/artikel/<%= post.slug %></a>
                            </div>
                        </div>

                        <div class="bg-surface-subtle p-3 rounded-lg border border-border-light/50 space-y-1 text-body-sm text-on-surface-variant">
                            <div><strong>Kategori:</strong> <%= post.category ? post.category.name : '-' %></div>
                            <div><strong>Sumber:</strong> <%= post.source === 'ai' ? `AI (Batch ${post.ai_job?.batch_name || post.ai_job_id || '-'})` : 'Manual' %></div>
                            <% if (post.status === 'scheduled') { %>
                                <div><strong>Jadwal Publish:</strong> <span class="text-blue-600 font-semibold"><%= formatJakartaDateTime(post.scheduled_at, { dateStyle: 'short', timeStyle: 'short' }) %></span></div>
                            <% } else if (post.status === 'published') { %>
                                <div><strong>Dipublish:</strong> <%= formatJakartaDateTime(post.published_at, { dateStyle: 'short', timeStyle: 'short' }) %></div>
                            <% } %>
                        </div>

                        <div class="flex items-center justify-between gap-2 pt-2 border-t border-border-light/50">
                            <div>
                                <% if (post.status === 'published') { %>
                                    <span class="bg-green-100 text-green-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-green-200">Published</span>
                                <% } else if (post.status === 'scheduled') { %>
                                    <span class="bg-blue-100 text-blue-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-blue-200">Scheduled</span>
                                <% } else if (post.status === 'draft') { %>
                                    <span class="bg-yellow-100 text-yellow-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-yellow-200">Draft</span>
                                <% } else if (post.status === 'archived') { %>
                                    <span class="bg-orange-100 text-orange-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-orange-200">Archived</span>
                                <% } else if (post.status === 'deleted') { %>
                                    <span class="bg-red-100 text-red-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-red-200">Deleted</span>
                                <% } %>
                            </div>

                            <div class="flex items-center gap-1.5">
                                <% if (post.status !== 'deleted') { %>
                                    <a href="/admin/blog/<%= post.id %>/edit" class="text-label-xs font-bold text-secondary hover:bg-secondary/5 px-2.5 py-1.5 rounded-lg border border-secondary/20 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[14px]">edit</span>
                                    </a>
                                    <form action="/admin/blog/<%= post.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin?')">
                                        <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                        <button type="submit" class="text-label-xs font-bold text-error hover:bg-error/5 p-1.5 rounded-lg border border-error/20 flex items-center justify-center cursor-pointer">
                                            <span class="material-symbols-outlined text-[14px]">delete</span>
                                        </button>
                                    </form>
                                <% } else { %>
                                    <form action="/admin/blog/<%= post.id %>/restore" method="POST" class="inline">
                                        <input type="hidden" name="csrfToken" value="<%= csrfToken %>">
                                        <button type="submit" class="text-green-600 bg-green-50 border border-green-200 px-2 py-1 rounded-md hover:bg-green-100 font-bold text-[10px] cursor-pointer">
                                            Restore
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
        <%- include('../../partials/pagination', { pagination }) %>
    </div>
</div>

<script>
    const bulkForm = document.getElementById('bulk-action-form');
    const bulkStatus = document.getElementById('bulk_status');
    const bulkScheduledAt = document.getElementById('bulk_scheduled_at');
    const checkAll = document.getElementById('bulk-check-all');
    const selectVisibleButton = document.getElementById('select-visible-posts');

    function getBulkCheckboxes() {
        return Array.from(document.querySelectorAll('.bulk-post-checkbox'));
    }

    function setBulkScheduleRequirement() {
        const isScheduled = bulkStatus.value === 'scheduled';
        bulkScheduledAt.toggleAttribute('required', isScheduled);
    }

    checkAll?.addEventListener('change', function() {
        getBulkCheckboxes().forEach(checkbox => {
            checkbox.checked = this.checked;
        });
    });

    selectVisibleButton?.addEventListener('click', function() {
        const checkboxes = getBulkCheckboxes();
        const shouldCheck = checkboxes.some(checkbox => !checkbox.checked);
        checkboxes.forEach(checkbox => {
            checkbox.checked = shouldCheck;
        });
        if (checkAll) checkAll.checked = shouldCheck;
    });

    bulkStatus?.addEventListener('change', setBulkScheduleRequirement);
    setBulkScheduleRequirement();

    bulkForm?.addEventListener('submit', function(event) {
        const selectedCount = getBulkCheckboxes().filter(checkbox => checkbox.checked).length;
        if (selectedCount === 0) {
            event.preventDefault();
            alert('Pilih minimal satu artikel terlebih dahulu.');
            return;
        }

        if (bulkStatus.value === 'scheduled' && !bulkScheduledAt.value) {
            event.preventDefault();
            alert('Isi jadwal publish untuk status Scheduled.');
        }
    });
</script>
