<div class="max-w-md mx-auto px-container-margin md:px-stack-lg py-12">
    <div class="bg-surface-container-lowest rounded-lg border border-border-light shadow-sm p-6 md:p-8 space-y-6">
        <div class="space-y-2">
            <h1 class="text-headline-md font-bold text-on-surface">Reset Kata Sandi</h1>
            <p class="text-body-sm text-on-surface-variant">Masukkan kata sandi baru untuk akun Anda.</p>
        </div>

        <% if (error) { %>
            <div class="bg-error-container text-on-error-container border border-error/20 p-4 rounded-xl text-body-md font-medium"><%= error %></div>
        <% } %>

        <form action="/auth/reset-password" method="POST" class="space-y-4">
            <input type="hidden" name="token" value="<%= token %>">
            <div class="space-y-1.5">
                <label class="text-label-sm font-bold text-on-surface-variant">Kata Sandi Baru</label>
                <div class="relative">
                    <input type="password" id="reset-password" name="password" required placeholder="Minimal 6 karakter" class="w-full pl-4 pr-12 py-2.5 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md">
                    <button type="button" data-password-toggle="reset-password" aria-label="Lihat kata sandi" class="absolute inset-y-0 right-0 px-3 text-outline hover:text-primary flex items-center">
                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                    </button>
                </div>
            </div>
            <div class="space-y-1.5">
                <label class="text-label-sm font-bold text-on-surface-variant">Konfirmasi Kata Sandi</label>
                <div class="relative">
                    <input type="password" id="reset-password-confirmation" name="passwordConfirmation" required placeholder="Ulangi kata sandi" class="w-full pl-4 pr-12 py-2.5 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md">
                    <button type="button" data-password-toggle="reset-password-confirmation" aria-label="Lihat kata sandi" class="absolute inset-y-0 right-0 px-3 text-outline hover:text-primary flex items-center">
                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                    </button>
                </div>
            </div>
            <button type="submit" class="w-full bg-primary text-on-primary py-3 rounded-lg text-label-md font-bold hover:bg-surface-tint transition-all cursor-pointer shadow-sm">
                Simpan Kata Sandi
            </button>
        </form>
    </div>
</div>

<script src="/js/password-toggle.js"></script>
