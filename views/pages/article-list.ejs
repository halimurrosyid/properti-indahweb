<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-12 space-y-12">
    <!-- Header Section with background design -->
    <div class="relative bg-gradient-to-br from-primary/10 via-surface-container-low to-secondary/10 p-8 md:p-12 rounded-3xl border border-border-light shadow-sm overflow-hidden text-center space-y-4">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_120%,rgba(var(--color-primary-rgb),0.08),transparent_50%)]"></div>
        <span class="bg-primary/10 text-primary font-bold text-label-sm px-3.5 py-1.5 rounded-full uppercase tracking-wider">Artikel & Panduan</span>
        <h1 class="text-headline-md md:text-display-sm font-extrabold text-on-surface tracking-tight max-w-2xl mx-auto">
            Tips, Trik & Info Properti Terbaru
        </h1>
        <p class="text-body-md md:text-title-medium text-on-surface-variant max-w-lg mx-auto">
            Dapatkan wawasan seputar investasi, tren pasar, dekorasi rumah, dan panduan hukum properti di Indonesia.
        </p>
    </div>

    <!-- Articles Grid -->
    <% if (articles.length === 0) { %>
        <div class="bg-surface-container-lowest rounded-2xl border border-border-light p-12 text-center space-y-4 shadow-sm">
            <span class="material-symbols-outlined text-[64px] text-outline">description_off</span>
            <h3 class="text-title-lg font-bold text-on-surface">Belum Ada Artikel</h3>
            <p class="text-body-md text-on-surface-variant max-w-xs mx-auto">
                Silakan kembali beberapa saat lagi untuk membaca panduan properti terbaru kami.
            </p>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% articles.forEach((article, idx) => { %>
                <article class="group bg-surface-container-lowest rounded-2xl border border-border-light overflow-hidden shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-300 flex flex-col">
                    <!-- Cover Image -->
                    <a href="/artikel/<%= article.slug %>" class="block aspect-[16/10] overflow-hidden bg-surface-container-high relative">
                        <% if (article.coverImage) { %>
                            <img src="<%= article.coverImage %>" alt="<%= article.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <% } else { %>
                            <!-- On-brand modern abstract SVG placeholder -->
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/5 to-secondary/5 text-primary/30">
                                <span class="material-symbols-outlined text-[64px]">article</span>
                            </div>
                        <% } %>
                    </a>

                    <!-- Content Card -->
                    <div class="p-6 flex-grow flex flex-col justify-between space-y-4">
                        <div class="space-y-2">
                            <!-- Meta Info -->
                            <div class="flex items-center gap-3 text-label-xs text-outline font-semibold">
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                    <%= new Date(article.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                </span>
                                <span>•</span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">schedule</span>
                                    <%= Math.max(2, Math.ceil((article.content || '').split(' ').length / 200)) %> mnt baca
                                </span>
                            </div>

                            <!-- Title -->
                            <h2 class="text-title-lg font-bold text-on-surface leading-snug group-hover:text-primary transition-colors line-clamp-2">
                                <a href="/artikel/<%= article.slug %>"><%= article.title %></a>
                            </h2>

                            <!-- Excerpt -->
                            <p class="text-body-sm text-on-surface-variant line-clamp-3">
                                <%= article.excerpt || (article.content || '').replace(/<[^>]*>/g, '').substring(0, 150) + '...' %>
                            </p>
                        </div>

                        <!-- Read Link -->
                        <div class="pt-4 border-t border-border-light flex items-center justify-between">
                            <a href="/artikel/<%= article.slug %>" class="text-label-sm font-extrabold text-primary flex items-center gap-1 group-hover:underline">
                                Selengkapnya <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</div>
