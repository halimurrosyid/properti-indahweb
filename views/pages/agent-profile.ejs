<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-12 space-y-12">
    <!-- Agent Profile Card Banner -->
    <div class="bg-surface-container-lowest rounded-3xl border border-border-light shadow-sm overflow-hidden p-6 md:p-10 flex flex-col md:flex-row items-center md:items-start gap-8 relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/5 via-transparent to-secondary/5 pointer-events-none"></div>
        
        <!-- Avatar Block -->
        <div class="w-24 h-24 md:w-32 md:h-32 bg-primary/10 text-primary border-4 border-surface-container-lowest shadow rounded-full flex items-center justify-center flex-shrink-0 z-10">
            <span class="material-symbols-outlined text-[56px] md:text-[80px]" style="font-variation-settings: 'FILL' 1;">account_circle</span>
        </div>

        <!-- Details block -->
        <div class="flex-grow space-y-4 text-center md:text-left z-10">
            <div class="space-y-1">
                <span class="bg-primary/10 text-primary font-bold text-label-xs px-3 py-1 rounded-full uppercase border border-primary/20">Agen Terverifikasi</span>
                <h1 class="text-headline-md md:text-headline-lg font-black text-on-surface tracking-tight mt-2"><%= agent.name %></h1>
                <p class="text-body-sm text-outline font-semibold">Tergabung sejak: <%= new Date(agent.createdAt).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %></p>
            </div>
            
            <p class="text-body-md text-on-surface-variant max-w-xl">
                Halo, saya siap membantu Anda menemukan properti terbaik di Indonesia. Silakan lihat katalog listing properti aktif yang saya pasarkan di bawah ini atau hubungi saya langsung.
            </p>

            <div class="flex flex-wrap justify-center md:justify-start gap-3 pt-2">
                <a href="https://wa.me/<%= agent.whatsapp %>" target="_blank" rel="noopener noreferrer" 
                   class="bg-whatsapp-green text-white font-bold text-label-md px-5 py-3 rounded-xl hover:opacity-90 transition-all flex items-center gap-1.5 shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">chat</span> Chat WhatsApp
                </a>
                <span class="bg-surface-container-high border border-border-light text-on-surface font-semibold text-label-md px-5 py-3 rounded-xl flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-[20px] text-primary">house</span> <%= properties.length %> Properti Aktif
                </span>
            </div>
        </div>
    </div>

    <!-- Agent Listings Grid -->
    <div class="space-y-6">
        <h2 class="text-title-lg font-black text-on-surface border-b border-border-light pb-3">Daftar Properti Oleh <%= agent.name %></h2>
        
        <% if (properties.length === 0) { %>
            <div class="bg-surface-container-lowest border border-border-light p-16 text-center rounded-3xl">
                <span class="material-symbols-outlined text-outline text-[64px] mb-3">house</span>
                <p class="text-body-md text-on-surface-variant">Saat ini agen tidak memiliki properti aktif yang ditayangkan.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <% properties.forEach(prop => { %>
                    <div class="<%= prop.isFeatured ? 'border-2 border-primary bg-primary/[0.01]' : 'border border-border-light bg-surface-container-lowest' %> rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all flex flex-col relative">
                        <% if (prop.isFeatured) { %>
                            <div class="absolute top-3 right-3 bg-primary text-white text-[11px] font-bold px-2 py-0.5 rounded-md shadow-sm flex items-center gap-0.5 z-20">
                                <span class="material-symbols-outlined text-[12px] font-bold">star</span> Premium
                            </div>
                        <% } %>
                        <div class="relative h-48 w-full bg-surface-container">
                            <% if (prop.images && prop.images.length > 0) { %>
                                <img src="<%= prop.images[0].url %>" alt="<%= prop.title %> - Properti Indahweb" title="<%= prop.title %>" class="object-cover w-full h-full" />
                            <% } else { %>
                                <div class="absolute inset-0 bg-primary/5 flex items-center justify-center text-primary/45">
                                    <span class="material-symbols-outlined text-[48px]">image</span>
                                </div>
                            <% } %>
                            <div class="absolute top-3 left-3 bg-whatsapp-green text-white text-label-sm font-bold px-2.5 py-1 rounded-full shadow-sm">
                                <%= prop.listingType === 'RENT' ? 'DISEWA' : 'DIJUAL' %>
                            </div>
                            <button 
                                class="absolute bottom-3 right-3 bg-surface-container-lowest/80 backdrop-blur text-on-surface hover:text-error w-8 h-8 rounded-full shadow flex items-center justify-center cursor-pointer transition-all z-20 favorite-card-btn"
                                data-id="<%= prop.id %>"
                                title="Simpan ke Favorit"
                            >
                                <span class="material-symbols-outlined text-[18px] text-outline favorite-card-icon">favorite</span>
                            </button>
                        </div>
                        <div class="p-4 flex-grow flex flex-col justify-between space-y-3">
                            <div>
                                <span class="text-primary text-label-sm font-bold"><%= prop.category.name %></span>
                                <h3 class="text-title-md font-bold text-on-surface line-clamp-1 mt-1">
                                    <a href="/property/<%= prop.slug %>" class="hover:underline"><%= prop.title %></a>
                                </h3>
                                <p class="text-body-sm text-outline line-clamp-1 mt-0.5"><%= prop.city %>, <%= prop.province %></p>
                                <p class="text-primary text-title-lg font-bold mt-2">
                                    Rp <%= Number(prop.price).toLocaleString('id-ID') %>
                                </p>
                            </div>
                            <div class="flex justify-between items-center border-t border-border-light pt-3 text-outline text-label-sm">
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">square_foot</span> Lb <%= prop.buildingSize %>m²
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">bed</span> <%= prop.bedrooms %> KT
                                </span>
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[16px]">bathtub</span> <%= prop.bathrooms %> KM
                                </span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cardButtons = document.querySelectorAll('.favorite-card-btn');

        function getFavorites() {
            const favs = localStorage.getItem('properti_favorit');
            return favs ? JSON.parse(favs) : [];
        }

        function saveFavorites(favs) {
            localStorage.setItem('properti_favorit', JSON.stringify(favs));
        }

        function updateCardUIs() {
            const favs = getFavorites();
            cardButtons.forEach(btn => {
                const id = parseInt(btn.getAttribute('data-id'));
                const icon = btn.querySelector('.favorite-card-icon');
                if (favs.includes(id)) {
                    icon.classList.remove('text-outline');
                    icon.classList.add('text-error');
                    icon.style.fontVariationSettings = "'FILL' 1";
                } else {
                    icon.classList.add('text-outline');
                    icon.classList.remove('text-error');
                    icon.style.fontVariationSettings = "'FILL' 0";
                }
            });
        }

        cardButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                const id = parseInt(btn.getAttribute('data-id'));
                let favs = getFavorites();
                if (favs.includes(id)) {
                    favs = favs.filter(item => item !== id);
                } else {
                    favs.push(id);
                }
                saveFavorites(favs);
                updateCardUIs();
            });
        });

        updateCardUIs();
    });
</script>
