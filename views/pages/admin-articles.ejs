<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-10 space-y-8">
    <!-- Header Section -->
    <div class="bg-surface-container-lowest p-6 rounded-2xl border border-border-light shadow-sm flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
            <h1 class="text-headline-md font-bold text-on-surface">Manajemen Artikel Blog</h1>
            <p class="text-body-sm text-on-surface-variant mt-1">Buat, edit, dan kelola publikasi artikel tips properti untuk SEO portal.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <a href="/admin/dashboard" class="text-on-surface-variant hover:text-primary transition-colors text-label-md font-bold px-4 py-2 rounded-lg border border-border-light flex items-center gap-1">
                <span class="material-symbols-outlined text-[18px]">admin_panel_settings</span> Peninjauan Properti
            </a>
            <a href="/artikel/admin/create" class="bg-primary hover:bg-surface-tint text-on-primary font-bold text-label-md px-5 py-2.5 rounded-full transition-all flex items-center gap-1.5 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">add</span> Tulis Artikel
            </a>
        </div>
    </div>

    <!-- Alert Message -->
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="bg-primary/10 text-primary border border-primary/20 p-4 rounded-xl text-body-md font-medium flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">info</span>
            <%= message %>
        </div>
    <% } %>

    <!-- URL query msg parameter -->
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const msg = urlParams.get('msg');
        if (msg) {
            document.write(`
                <div class="bg-primary/10 text-primary border border-primary/20 p-4 rounded-xl text-body-md font-medium flex items-center gap-2 mb-6">
                    <span class="material-symbols-outlined text-primary">info</span>
                    ${msg}
                </div>
            `);
        }
    </script>

    <!-- Articles Table Container -->
    <div class="bg-surface-container-lowest rounded-2xl border border-border-light shadow-sm overflow-hidden">
        <div class="p-6 border-b border-border-light flex justify-between items-center bg-surface-container-low/50">
            <h2 class="text-title-lg font-bold text-on-surface font-display-md">Daftar Artikel (<%= articles.length %>)</h2>
        </div>

        <% if (articles.length === 0) { %>
            <div class="p-12 text-center space-y-4">
                <span class="material-symbols-outlined text-[64px] text-outline">article</span>
                <p class="text-body-md text-on-surface-variant max-w-sm mx-auto">Belum ada artikel yang dibuat. Klik tombol "Tulis Artikel" di atas untuk memulai.</p>
            </div>
        <% } else { %>
            <!-- Desktop Table View -->
            <div class="hidden md:block overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low text-label-sm font-bold text-on-surface-variant border-b border-border-light">
                            <th class="p-4">Cover</th>
                            <th class="p-4">Judul Artikel</th>
                            <th class="p-4">Tanggal Dibuat</th>
                            <th class="p-4">Status Publikasi</th>
                            <th class="p-4 text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-light">
                        <% articles.forEach(article => { %>
                            <tr class="hover:bg-surface-bright/50 transition-all text-body-md text-on-surface">
                                <!-- Cover thumbnail -->
                                <td class="p-4">
                                    <% if (article.coverImage) { %>
                                        <img src="<%= article.coverImage %>" alt="<%= article.title %> - 1rumah.biz.id" title="<%= article.title %>" class="w-16 h-10 object-cover rounded border border-border-light">
                                    <% } else { %>
                                        <div class="w-16 h-10 bg-surface-container-high rounded border border-border-light flex items-center justify-center text-outline">
                                            <span class="material-symbols-outlined text-[18px]">image</span>
                                        </div>
                                    <% } %>
                                </td>

                                <!-- Title and slug -->
                                <td class="p-4">
                                    <span class="font-semibold text-on-surface block max-w-sm truncate"><%= article.title %></span>
                                    <a href="/artikel/<%= article.slug %>" target="_blank" class="text-label-xs text-primary hover:underline font-mono block mt-0.5">/artikel/<%= article.slug %></a>
                                </td>

                                <!-- Date created -->
                                <td class="p-4 text-body-sm text-outline">
                                    <%= new Date(article.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                </td>

                                <!-- Status Toggle -->
                                <td class="p-4">
                                    <form action="/artikel/admin/<%= article.id %>/toggle-publish" method="POST" class="inline">
                                        <button type="submit" class="text-label-xs font-bold px-3 py-1.5 rounded-full border transition-all cursor-pointer <%= article.isPublished ? 'bg-green-50 text-green-700 border-green-200 hover:bg-green-100' : 'bg-yellow-50 text-yellow-700 border-yellow-200 hover:bg-yellow-100' %>">
                                            <%= article.isPublished ? 'Published' : 'Draft' %> (Klik Ubah)
                                        </button>
                                    </form>
                                </td>

                                <!-- Actions -->
                                <td class="p-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <!-- Edit button -->
                                        <a href="/artikel/admin/<%= article.id %>/edit" class="text-label-sm font-bold text-secondary hover:bg-secondary/5 px-2.5 py-1.5 rounded-lg border border-secondary/20 transition-all flex items-center gap-1" title="Edit Artikel">
                                            <span class="material-symbols-outlined text-[16px]">edit</span> Edit
                                        </a>

                                        <!-- Delete form -->
                                        <form action="/artikel/admin/<%= article.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Apakah Anda yakin ingin menghapus artikel ini secara permanen?')">
                                            <button type="submit" class="text-label-sm font-bold text-error hover:bg-error/5 p-1.5 rounded-lg border border-error/20 transition-all cursor-pointer flex items-center justify-center" title="Hapus Permanen">
                                                <span class="material-symbols-outlined text-[18px]">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Mobile List Card View -->
            <div class="block md:hidden divide-y divide-border-light">
                <% articles.forEach(article => { %>
                    <div class="p-4 space-y-3">
                        <div class="flex gap-3">
                            <% if (article.coverImage) { %>
                                <img src="<%= article.coverImage %>" alt="<%= article.title %> - 1rumah.biz.id" title="<%= article.title %>" class="w-16 h-12 object-cover rounded border border-border-light flex-shrink-0">
                            <% } else { %>
                                <div class="w-16 h-12 bg-surface-container-high rounded border border-border-light flex items-center justify-center text-outline flex-shrink-0">
                                    <span class="material-symbols-outlined text-[20px]">image</span>
                                </div>
                            <% } %>
                            <div class="min-w-0 flex-grow">
                                <span class="font-semibold text-on-surface block truncate text-body-md"><%= article.title %></span>
                                <a href="/artikel/<%= article.slug %>" target="_blank" class="text-label-xs text-primary hover:underline font-mono block mt-0.5 truncate">/artikel/<%= article.slug %></a>
                            </div>
                        </div>

                        <div class="flex items-center justify-between gap-2 pt-2 border-t border-border-light/50">
                            <form action="/artikel/admin/<%= article.id %>/toggle-publish" method="POST" class="inline">
                                <button type="submit" class="text-label-xs font-bold px-2.5 py-1 rounded-full border <%= article.isPublished ? 'bg-green-50 text-green-700 border-green-200' : 'bg-yellow-50 text-yellow-700 border-yellow-200' %>">
                                    <%= article.isPublished ? 'Published' : 'Draft' %>
                                </button>
                            </form>

                            <div class="flex items-center gap-2">
                                <a href="/artikel/admin/<%= article.id %>/edit" class="text-label-xs font-bold text-secondary hover:bg-secondary/5 px-2.5 py-1 rounded-lg border border-secondary/20 transition-all flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">edit</span> Edit
                                </a>
                                <form action="/artikel/admin/<%= article.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Hapus artikel ini?')">
                                    <button type="submit" class="text-label-xs font-bold text-error hover:bg-error/5 p-1 rounded-lg border border-error/20 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[14px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
