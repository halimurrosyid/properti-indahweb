<div class="max-w-7xl mx-auto px-container-margin md:px-stack-lg py-16 space-y-12">
    <!-- Header -->
    <div class="text-center space-y-3">
        <span class="text-primary text-label-md font-bold tracking-widest uppercase">Paket & Layanan Iklan</span>
        <h1 class="text-headline-md md:text-headline-lg font-bold text-on-surface">Maksimalkan Penjualan Properti Anda</h1>
        <p class="text-body-sm md:text-body-md text-on-surface-variant max-w-xl mx-auto">
            Dapatkan eksposur dan jangkauan calon pembeli lebih tinggi dengan meletakkan properti Anda di slot Featured Premium kami.
        </p>
    </div>

    <!-- Alur Pemesanan Visual Guide -->
    <div class="bg-primary/5 rounded-lg border border-primary/10 p-6 md:p-8 max-w-4xl mx-auto">
        <h3 class="text-title-md font-bold text-primary text-center mb-6 uppercase tracking-wider">Alur Cara Pemasangan & Pemilihan Paket</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div class="space-y-2">
                <div class="w-10 h-10 rounded-full bg-primary text-on-primary font-bold flex items-center justify-center mx-auto mb-2 text-label-md">1</div>
                <h4 class="text-label-md font-extrabold text-on-surface">Isi Detail Properti</h4>
                <p class="text-body-xs text-on-surface-variant leading-relaxed">Pilih paket di bawah dan klik tombol mulai. Isi lengkap detail spesifikasi, lokasi, dan unggah foto properti Anda.</p>
            </div>
            <div class="space-y-2">
                <div class="w-10 h-10 rounded-full bg-primary text-on-primary font-bold flex items-center justify-center mx-auto mb-2 text-label-md">2</div>
                <h4 class="text-label-md font-extrabold text-on-surface">Konfirmasi Paket</h4>
                <p class="text-body-xs text-on-surface-variant leading-relaxed">Di akhir formulir pasang iklan, konfirmasi paket yang dipilih (Gratis atau berbayar melalui transfer bank).</p>
            </div>
            <div class="space-y-2">
                <div class="w-10 h-10 rounded-full bg-primary text-on-primary font-bold flex items-center justify-center mx-auto mb-2 text-label-md">3</div>
                <h4 class="text-label-md font-extrabold text-on-surface">Persetujuan & Tayang</h4>
                <p class="text-body-xs text-on-surface-variant leading-relaxed">Admin akan memoderasi iklan Anda. Setelah disetujui, iklan properti Anda otomatis langsung tayang secara publik!</p>
            </div>
        </div>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
        <% adPackages.forEach(pkg => { 
            const benefits = parseBenefits(pkg.benefits);
            const price = Number(pkg.price || 0);
        %>
            <div class="bg-surface-container-lowest p-6 rounded-lg <%= pkg.isPopular ? 'border-2 border-primary shadow-md' : 'border border-border-light shadow-sm' %> flex flex-col justify-between hover:shadow-md transition-all relative overflow-hidden">
                <% if (pkg.isPopular) { %>
                    <div class="absolute top-3 right-3 bg-primary text-on-primary font-bold text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider">Terpopuler</div>
                <% } %>
                <div class="space-y-4">
                    <div class="space-y-1.5 pr-20">
                        <h3 class="text-title-lg font-bold text-on-surface"><%= pkg.name %></h3>
                        <p class="text-body-sm text-outline"><%= pkg.description || 'Paket promosi properti' %></p>
                    </div>
                    <div class="pt-2">
                        <span class="text-headline-sm font-bold <%= price > 0 ? 'text-primary' : 'text-on-surface' %>">Rp <%= formatPackagePrice(pkg.price) %></span>
                        <span class="text-body-sm text-outline">/ <%= pkg.durationDays ? `${pkg.durationDays} hari` : 'selamanya' %></span>
                    </div>
                    <hr class="border-border-light" />
                    <ul class="text-body-sm text-on-surface-variant space-y-3">
                        <% benefits.forEach(benefit => { %>
                            <li class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[18px] text-primary mt-0.5">check_circle</span>
                                <span><%= benefit %></span>
                            </li>
                        <% }) %>
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[18px] text-primary mt-0.5">check_circle</span>
                            <span>Maksimal <%= pkg.listingLimit %> iklan aktif</span>
                        </li>
                    </ul>
                </div>
                <a href="/pasang-iklan?package=<%= encodeURIComponent(pkg.code) %>" class="w-full <%= price > 0 ? 'bg-primary text-on-primary hover:bg-surface-tint' : 'bg-surface-container-high text-on-surface-variant hover:bg-surface-container-highest' %> text-center py-3 rounded-lg text-label-md font-bold transition-all block mt-8 shadow-sm">
                    <%= price > 0 ? 'Pilih Paket Ini' : 'Mulai Pasang Gratis' %>
                </a>
            </div>
        <% }) %>
    </div>
</div>
