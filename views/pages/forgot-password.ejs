<div class="max-w-md mx-auto px-container-margin md:px-stack-lg py-12">
    <div class="bg-surface-container-lowest rounded-2xl border border-border-light shadow-sm p-6 md:p-8 space-y-6">
        <div class="space-y-2">
            <h1 class="text-headline-md font-bold text-on-surface">Lupa Kata Sandi</h1>
            <p class="text-body-sm text-on-surface-variant">Masukkan email atau WhatsApp akun Anda. Jika email tersedia, kami akan mengirim link reset.</p>
        </div>

        <% if (error) { %>
            <div class="bg-error-container text-on-error-container border border-error/20 p-4 rounded-xl text-body-md font-medium"><%= error %></div>
        <% } %>
        <% if (message) { %>
            <div class="bg-green-50 text-green-800 border border-green-200 p-4 rounded-xl text-body-md font-medium"><%= message %></div>
        <% } %>

        <form action="/auth/forgot-password" method="POST" class="space-y-4">
            <div class="space-y-1.5">
                <label class="text-label-sm font-bold text-on-surface-variant">Email atau WhatsApp</label>
                <input type="text" name="identity" required placeholder="email@domain.com / 628..." class="w-full px-4 py-2.5 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md">
            </div>
            <button type="submit" class="w-full bg-primary text-on-primary py-3 rounded-lg text-label-md font-bold hover:bg-surface-tint transition-all cursor-pointer shadow-sm">
                Kirim Link Reset
            </button>
        </form>

        <p class="text-center text-body-sm text-on-surface-variant">
            Ingat kata sandi? <a href="/auth/login" class="text-primary font-bold hover:underline">Masuk</a>
        </p>
    </div>
</div>
