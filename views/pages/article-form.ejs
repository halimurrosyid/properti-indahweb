<%
  const isEdit = typeof article !== 'undefined' && article !== null;
  const formAction = isEdit ? `/artikel/admin/${article.id}/edit` : '/artikel/admin/create';
  const pageTitle = isEdit ? 'Edit Artikel' : 'Tulis Artikel Baru';
%>

<div class="max-w-4xl mx-auto px-container-margin md:px-stack-lg py-10 space-y-8">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-label-sm text-outline">
        <a href="/admin/dashboard" class="hover:text-primary transition-colors">Admin Panel</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <a href="/artikel/admin" class="hover:text-primary transition-colors">Kelola Artikel</a>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
        <span class="text-on-surface"><%= pageTitle %></span>
    </nav>

    <!-- Header Section -->
    <div class="bg-surface-container-lowest p-6 rounded-2xl border border-border-light shadow-sm flex justify-between items-center">
        <div>
            <h1 class="text-headline-md font-bold text-on-surface"><%= pageTitle %></h1>
            <p class="text-body-sm text-on-surface-variant mt-1">Isi formulir di bawah ini untuk membuat atau memperbarui artikel blog.</p>
        </div>
    </div>

    <!-- Form Container -->
    <div class="bg-surface-container-lowest rounded-2xl border border-border-light shadow-sm overflow-hidden p-6 md:p-8">
        <form action="<%= formAction %>" method="POST" enctype="multipart/form-data" class="space-y-6">
            
            <!-- Title -->
            <div class="space-y-2">
                <label for="title" class="text-label-md font-bold text-on-surface block">Judul Artikel <span class="text-error">*</span></label>
                <input type="text" id="title" name="title" required placeholder="Contoh: 5 Tips Membeli Rumah Pertama untuk Milenial" 
                       value="<%= isEdit ? article.title : '' %>"
                       class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-4 py-3 text-body-md focus:border-primary focus:bg-surface-bright focus:outline-none transition-all">
            </div>

            <!-- Excerpt (Meta Description) -->
            <div class="space-y-2">
                <label for="excerpt" class="text-label-md font-bold text-on-surface block">Kutipan Singkat (Excerpt) / Meta Description</label>
                <textarea id="excerpt" name="excerpt" rows="2" placeholder="Tuliskan rangkuman artikel 1-2 kalimat untuk pratinjau halaman katalog dan SEO Google (rekomendasi maks 150 karakter)."
                          class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-4 py-3 text-body-md focus:border-primary focus:bg-surface-bright focus:outline-none transition-all"><%= isEdit ? article.excerpt : '' %></textarea>
            </div>

            <!-- Cover Image File Upload -->
            <div class="space-y-2">
                <label for="coverImage" class="text-label-md font-bold text-on-surface block">Foto Sampul (Cover Image)</label>
                
                <% if (isEdit && article.coverImage) { %>
                    <div class="mb-3 space-y-2">
                        <span class="text-body-xs text-outline block">Foto Sampul Saat Ini:</span>
                        <img src="<%= article.coverImage %>" alt="Cover" class="w-48 aspect-[16/10] object-cover rounded-lg border border-border-light bg-surface-container-low">
                    </div>
                <% } %>

                <input type="file" id="coverImage" name="coverImage" accept="image/*"
                       class="w-full text-body-sm text-outline border border-border-light rounded-xl px-4 py-3 bg-surface-container-low focus:outline-none file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-label-sm file:font-semibold file:bg-primary file:text-on-primary hover:file:bg-surface-tint file:cursor-pointer transition-all">
                <span class="text-body-xs text-outline block">Format gambar yang didukung: JPG, PNG, WEBP (Maksimal 3MB)</span>
            </div>

            <!-- Article Content Body -->
            <div class="space-y-2">
                <label for="content" class="text-label-md font-bold text-on-surface block">Isi Artikel / Konten Lengkap <span class="text-error">*</span></label>
                <textarea id="content" name="content" required rows="12" placeholder="Tuliskan isi artikel lengkap di sini secara informatif dan menarik..."
                          class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-4 py-3 text-body-md focus:border-primary focus:bg-surface-bright focus:outline-none transition-all font-sans leading-relaxed"><%= isEdit ? article.content : '' %></textarea>
            </div>

            <!-- Publication Status Option -->
            <div class="space-y-2">
                <label for="isPublished" class="text-label-md font-bold text-on-surface block">Status Publikasi</label>
                <select id="isPublished" name="isPublished" 
                        class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-4 py-3 text-body-md focus:border-primary focus:bg-surface-bright focus:outline-none transition-all cursor-pointer">
                    <option value="false" <%= (isEdit && !article.isPublished) ? 'selected' : '' %>>Simpan Sebagai Draft (Belum Dipublikasikan)</option>
                    <option value="true" <%= (!isEdit || article.isPublished) ? 'selected' : '' %>>Publikasikan Segera (Tersedia untuk Publik)</option>
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="pt-6 border-t border-border-light flex items-center justify-end gap-3">
                <a href="/artikel/admin" class="text-label-md font-bold text-on-surface-variant hover:bg-surface-container-high px-5 py-3 rounded-full border border-border-light transition-all">
                    Batal
                </a>
                <button type="submit" class="bg-primary hover:bg-surface-tint text-on-primary text-label-md font-bold px-6 py-3 rounded-full transition-all shadow-sm cursor-pointer">
                    <%= isEdit ? 'Simpan Perubahan' : 'Buat Artikel' %>
                </button>
            </div>
        </form>
    </div>
</div>
