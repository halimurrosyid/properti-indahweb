<div class="max-w-6xl mx-auto px-container-margin md:px-stack-lg py-10 space-y-8">
    <div class="bg-surface-container-lowest p-6 rounded-2xl border border-border-light shadow-sm flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div>
            <h1 class="text-headline-md font-bold text-on-surface">Kelola Lokasi Populer</h1>
            <p class="text-body-sm text-on-surface-variant mt-1">Atur gambar kota pada bagian Jelajahi Lokasi. Urutan tampil otomatis mengikuti jumlah properti aktif terbanyak.</p>
        </div>
        <a href="/admin/dashboard" class="text-on-surface-variant hover:text-primary transition-colors text-label-md font-bold px-4 py-2.5 rounded-xl border border-border-light bg-surface-container-lowest">
            Kembali ke Panel Admin
        </a>
    </div>

    <% if (message) { %>
        <div class="bg-green-50 text-green-800 border border-green-200 p-4 rounded-xl text-body-md font-medium"><%= message %></div>
    <% } %>
    <% if (error) { %>
        <div class="bg-red-50 text-red-800 border border-red-200 p-4 rounded-xl text-body-md font-medium"><%= error %></div>
    <% } %>

    <div class="bg-surface-container-lowest rounded-2xl border border-border-light shadow-sm overflow-hidden">
        <div class="p-5 border-b border-border-light bg-surface-container-low/50">
            <h2 class="text-title-md font-bold text-on-surface">Tambah Lokasi Baru</h2>
        </div>
        <form action="/admin/locations" method="POST" enctype="multipart/form-data" class="p-5 grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div class="space-y-1">
                <label class="text-label-sm font-bold text-on-surface block">Kota</label>
                <input type="text" name="name" required class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
            </div>
            <div class="space-y-1">
                <label class="text-label-sm font-bold text-on-surface block">Provinsi</label>
                <input type="text" name="province" required class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
            </div>
            <div class="space-y-1">
                <label class="text-label-sm font-bold text-on-surface block">Upload Gambar</label>
                <input type="file" name="imageFile" accept="image/*" required class="w-full text-body-xs border border-border-light rounded-xl px-3 py-2 bg-surface-container-low">
            </div>
            <div class="flex items-center gap-3">
                <label class="flex items-center gap-1 text-label-sm font-bold text-on-surface">
                    <input type="checkbox" name="isActive" checked class="accent-primary"> Aktif
                </label>
                <button type="submit" class="bg-primary hover:bg-surface-tint text-on-primary text-label-sm font-bold px-4 py-2.5 rounded-xl cursor-pointer">Tambah</button>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 gap-4">
        <% cities.forEach(city => { %>
            <form action="/admin/locations/<%= city.id %>" method="POST" enctype="multipart/form-data" class="bg-surface-container-lowest rounded-2xl border border-border-light shadow-sm p-4 grid grid-cols-1 lg:grid-cols-[180px_1fr_auto] gap-4 items-center">
                <div class="relative h-28 rounded-xl overflow-hidden bg-surface-container border border-border-light">
                    <% if (city.imageUrl) { %>
                        <img src="<%= city.imageUrl %>" alt="Properti di <%= city.name %>" title="Properti di <%= city.name %>" class="absolute inset-0 w-full h-full object-cover">
                    <% } else { %>
                        <div class="absolute inset-0 flex items-center justify-center text-outline">
                            <span class="material-symbols-outlined text-[36px]">image</span>
                        </div>
                    <% } %>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <div class="absolute bottom-3 left-3 text-white">
                        <div class="font-bold text-body-md"><%= city.name %></div>
                        <div class="text-label-xs"><%= city.province %> • <%= city.propertyCount || 0 %> properti aktif</div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div class="space-y-1">
                        <label class="text-label-sm font-bold text-on-surface block">Kota</label>
                        <input type="text" name="name" value="<%= city.name %>" required class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-label-sm font-bold text-on-surface block">Provinsi</label>
                        <input type="text" name="province" value="<%= city.province %>" required class="w-full bg-surface-container-low text-on-surface border border-border-light rounded-xl px-3 py-2.5 text-body-sm focus:border-primary focus:outline-none">
                    </div>
                    <div class="space-y-1">
                        <label class="text-label-sm font-bold text-on-surface block">Upload Gambar Pengganti</label>
                        <input type="file" name="imageFile" accept="image/*" class="w-full text-body-xs border border-border-light rounded-xl px-3 py-2 bg-surface-container-low">
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="space-y-1 min-w-32">
                            <span class="text-label-sm font-bold text-on-surface block">Popularitas</span>
                            <span class="inline-flex bg-primary/10 text-primary font-bold text-label-sm px-3 py-2 rounded-xl border border-primary/20"><%= city.propertyCount || 0 %> properti aktif</span>
                        </div>
                        <label class="flex items-center gap-1 text-label-sm font-bold text-on-surface pt-6">
                            <input type="checkbox" name="isActive" <%= city.isActive ? 'checked' : '' %> class="accent-primary"> Aktif
                        </label>
                    </div>
                </div>

                <div class="flex lg:flex-col gap-2 lg:items-stretch">
                    <button type="submit" class="bg-primary hover:bg-surface-tint text-on-primary text-label-sm font-bold px-4 py-2.5 rounded-xl cursor-pointer">Simpan</button>
                    <button type="submit" formaction="/admin/locations/<%= city.id %>/delete" class="text-error border border-error/20 hover:bg-error/5 text-label-sm font-bold px-4 py-2.5 rounded-xl cursor-pointer" onclick="return confirm('Hapus lokasi <%= city.name %>?')">Hapus</button>
                </div>
            </form>
        <% }) %>
    </div>
</div>
