<div class="max-w-md mx-auto px-container-margin py-16">
    <div class="bg-surface-container-lowest p-6 md:p-8 rounded-2xl border border-border-light shadow-md space-y-6">
        <div class="text-center space-y-2">
            <h1 class="text-headline-md font-bold text-on-surface font-display-lg">Masuk ke Akun Anda</h1>
            <p class="text-body-sm text-on-surface-variant">Masuk untuk mengelola listing properti Anda di 1rumah.biz.id.</p>
        </div>

        <!-- Alert Error -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-error-container text-on-error-container border border-error/20 p-3 rounded-lg text-body-sm font-medium">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-4">
            <div class="space-y-1.5">
                <label class="text-label-sm font-bold text-on-surface-variant">Email / Nomor WhatsApp</label>
                <input 
                    type="text" 
                    name="identity" 
                    required 
                    placeholder="nama@email.com atau 628xxx" 
                    class="w-full px-4 py-2.5 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                />
            </div>

            <div class="space-y-1.5">
                <label class="text-label-sm font-bold text-on-surface-variant">Kata Sandi</label>
                <div class="relative">
                    <input 
                        type="password" 
                        id="login-password"
                        name="password" 
                        required 
                        placeholder="Masukkan kata sandi..." 
                        class="w-full pl-4 pr-12 py-2.5 rounded-lg border border-border-light focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-surface-bright text-body-md"
                    />
                    <button type="button" data-password-toggle="login-password" aria-label="Lihat kata sandi" class="absolute inset-y-0 right-0 px-3 text-outline hover:text-primary flex items-center">
                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                    </button>
                </div>
            </div>

            <div class="text-right">
                <a href="/auth/forgot-password" class="text-label-sm font-bold text-primary hover:underline">Lupa kata sandi?</a>
            </div>

            <button 
                type="submit" 
                class="w-full bg-primary text-on-primary py-3 rounded-lg text-label-md font-semibold hover:bg-surface-tint transition-all shadow-sm cursor-pointer mt-2"
            >
                Masuk Sekarang
            </button>
        </form>

        <p class="text-body-sm text-center text-on-surface-variant">
            Belum punya akun? <a href="/auth/register" class="text-primary font-bold hover:underline">Daftar Baru</a>
        </p>
    </div>
</div>

<script src="/js/password-toggle.js"></script>
