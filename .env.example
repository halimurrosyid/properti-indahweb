# =========================================================================
# TEMPLATE KONFIGURASI ENV - PROPERTI INDAHWEB
# =========================================================================
# Salin file ini menjadi ".env" dan sesuaikan nilainya untuk deployment.

# 1. Konfigurasi Server Utama
PORT=3000
NODE_ENV=production
SITE_URL=https://properti.indahweb.com
TZ=Asia/Jakarta
UPLOAD_DIR=/data/uploads
SESSION_SECRET=ganti_dengan_kunci_rahasia_acak_yang_panjang_dan_aman_123456

# 2. Konfigurasi Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# - Jika menggunakan Docker/Dokploy, HOST disesuaikan dengan nama service database (misal: "db").
DATABASE_URL="postgresql://postgres:password@db:5432/postgres"

# 3. Kredensial Super Admin Utama (Digunakan saat npx prisma db seed / inisialisasi awal)
SUPER_ADMIN_EMAIL=admin@properti.indahweb.com
SUPER_ADMIN_PASSWORD=adminindahweb
SUPER_ADMIN_NAME="Super Admin Indahweb"
SUPER_ADMIN_WHATSAPP=628123456789

# 4. Konfigurasi AI Anthropic & Blog SEO
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AI_BLOG_MAX_TITLES_PER_BATCH=50
AI_BLOG_DEFAULT_WORD_MIN=900
AI_BLOG_DEFAULT_WORD_MAX=1500
APP_TIMEZONE=Asia/Jakarta
UPLOAD_MAX_SIZE_MB=3
